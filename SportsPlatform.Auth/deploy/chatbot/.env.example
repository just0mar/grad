CHATBOT_BIND_ADDRESS=0.0.0.0
CHATBOT_PORT=8000

GROQ_API_KEY=replace-with-your-groq-api-key
GROQ_MODEL=replace-with-a-model-enabled-for-your-account
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT=60
FAST_ANALYTICS_BYPASS=0
ENABLE_ANALYTICS_LLM_FORMATTING=0
WARM_MODELS_ON_STARTUP=1

BACKEND_BASE_URL=http://backend.internal:5122
BACKEND_CHATBOT_SERVICE_TOKEN=replace-with-the-same-token-as-the-backend-machine
APP_API_TIMEOUT=8
APP_API_TIMEOUT_INTERACTIVE=3
WEBHOOK_PULL_TIMEOUT=60

PREDICTION_BASE_URL=http://prediction.internal:8101
CHATBOT_PREDICTION_SERVICE_TOKEN=replace-with-one-shared-random-token
PREDICTION_SERVICE_TIMEOUT=900

CELERY_WORKER_CONCURRENCY=4
