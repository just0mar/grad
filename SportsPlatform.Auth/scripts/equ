--
-- TOC entry 341 (class 1255 OID 19941)
-- Name: revoke_all_user_tokens(uuid, character varying); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.revoke_all_user_tokens(p_user_id uuid, p_reason character varying DEFAULT 'logout_all'::character varying) RETURNS integer
    LANGUAGE plpgsql
    AS $$
DECLARE
    rows_affected INT;
BEGIN
    UPDATE refresh_token
    SET    revoked_at     = NOW(),
           revoked_reason = p_reason
    WHERE  user_id   = p_user_id
      AND  revoked_at IS NULL;

    GET DIAGNOSTICS rows_affected = ROW_COUNT;
    RETURN rows_affected;   -- caller can log how many sessions were killed
END;
$$;


ALTER FUNCTION public.revoke_all_user_tokens(p_user_id uuid, p_reason character varying) OWNER TO postgres;

