--
-- TOC entry 240 (class 1259 OID 19614)
-- Name: player_cumulative_stats; Type: MATERIALIZED VIEW; Schema: public; Owner: postgres
--

CREATE MATERIALIZED VIEW public.player_cumulative_stats AS
 SELECT pgs.player_id,
    pgs.season_id,
    s.label AS season_label,
    count(*) AS matches_played,
    sum(pgs.minutes_played) AS total_minutes,
    sum(pgs.points) AS total_points,
    sum(pgs.rebounds) AS total_rebounds,
    sum(pgs.assists) AS total_assists,
    sum(pgs.steals) AS total_steals,
    sum(pgs.blocks) AS total_blocks,
    sum(pgs.turnovers) AS total_turnovers,
    sum(pgs.personal_fouls) AS total_fouls,
    sum(pgs.fg_made) AS total_fg_made,
    sum(pgs.fg_attempted) AS total_fg_attempted,
    sum(pgs.three_made) AS total_three_made,
    sum(pgs.ft_made) AS total_ft_made,
    round(avg(pgs.game_efficiency), 2) AS avg_efficiency
   FROM (public.player_game_stats pgs
     JOIN public.season s USING (season_id))
  GROUP BY pgs.player_id, pgs.season_id, s.label
  WITH NO DATA;


ALTER MATERIALIZED VIEW public.player_cumulative_stats OWNER TO postgres;

