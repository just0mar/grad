CREATE TABLE public.team_game_stats (
    report_id uuid DEFAULT gen_random_uuid() NOT NULL,
    match_id uuid NOT NULL,
    season_id uuid NOT NULL,
    analyst_staff_id uuid,
    points_scored integer DEFAULT 0 NOT NULL,
    points_conceded integer DEFAULT 0 NOT NULL,
    total_rebounds integer DEFAULT 0 NOT NULL,
    total_turnovers integer DEFAULT 0 NOT NULL,
    total_fouls integer DEFAULT 0 NOT NULL,
    total_assists integer DEFAULT 0 NOT NULL,
    total_steals integer DEFAULT 0 NOT NULL,
    total_blocks integer DEFAULT 0 NOT NULL,
    total_fg_made integer DEFAULT 0 NOT NULL,
    total_fg_attempted integer DEFAULT 0 NOT NULL,
    total_three_made integer DEFAULT 0 NOT NULL,
    total_ft_made integer DEFAULT 0 NOT NULL,
    team_efficiency numeric(6,2),
    created_at timestamp with time zone DEFAULT now() NOT NULL,
    updated_at timestamp with time zone DEFAULT now() NOT NULL,
    CONSTRAINT chk_tgs_3pt CHECK ((total_three_made <= total_fg_attempted)),
    CONSTRAINT chk_tgs_fg CHECK ((total_fg_made <= total_fg_attempted)),
    CONSTRAINT team_game_stats_points_conceded_check CHECK ((points_conceded >= 0)),
    CONSTRAINT team_game_stats_points_scored_check CHECK ((points_scored >= 0)),
    CONSTRAINT team_game_stats_total_assists_check CHECK ((total_assists >= 0)),
    CONSTRAINT team_game_stats_total_blocks_check CHECK ((total_blocks >= 0)),
    CONSTRAINT team_game_stats_total_fg_attempted_check CHECK ((total_fg_attempted >= 0)),
    CONSTRAINT team_game_stats_total_fg_made_check CHECK ((total_fg_made >= 0)),
    CONSTRAINT team_game_stats_total_fouls_check CHECK ((total_fouls >= 0)),
    CONSTRAINT team_game_stats_total_ft_made_check CHECK ((total_ft_made >= 0)),
    CONSTRAINT team_game_stats_total_rebounds_check CHECK ((total_rebounds >= 0)),
    CONSTRAINT team_game_stats_total_steals_check CHECK ((total_steals >= 0)),
    CONSTRAINT team_game_stats_total_three_made_check CHECK ((total_three_made >= 0)),
    CONSTRAINT team_game_stats_total_turnovers_check CHECK ((total_turnovers >= 0))
);


ALTER TABLE public.team_game_stats OWNER TO postgres;

--
-- TOC entry 241 (class 1259 OID 19627)
-- Name: team_cumulative_stats; Type: MATERIALIZED VIEW; Schema: public; Owner: postgres
--

CREATE MATERIALIZED VIEW public.team_cumulative_stats AS
 SELECT m.season_id,
    s.label AS season_label,
    e.team_id,
    count(*) AS matches_played,
    sum(
        CASE
            WHEN (m.result = 'Win'::public.match_result) THEN 1
            ELSE 0
        END) AS wins,
    sum(
        CASE
            WHEN (m.result = 'Loss'::public.match_result) THEN 1
            ELSE 0
        END) AS losses,
    sum(
        CASE
            WHEN (m.result = 'Draw'::public.match_result) THEN 1
            ELSE 0
        END) AS draws,
    sum(tgs.points_scored) AS total_points_scored,
    sum(tgs.points_conceded) AS total_points_conceded,
    sum(tgs.total_rebounds) AS total_rebounds,
    sum(tgs.total_assists) AS total_assists,
    sum(tgs.total_steals) AS total_steals,
    sum(tgs.total_blocks) AS total_blocks,
    sum(tgs.total_turnovers) AS total_turnovers,
    sum(tgs.total_fouls) AS total_fouls,
    sum(tgs.total_fg_made) AS total_fg_made,
    sum(tgs.total_fg_attempted) AS total_fg_attempted,
    sum(tgs.total_three_made) AS total_three_made,
    sum(tgs.total_ft_made) AS total_ft_made,
    round(avg(tgs.team_efficiency), 2) AS avg_efficiency
   FROM (((public.match m
     JOIN public.event e USING (event_id))
     JOIN public.season s ON ((s.season_id = m.season_id)))
     JOIN public.team_game_stats tgs ON ((tgs.match_id = m.match_id)))
  GROUP BY m.season_id, s.label, e.team_id
  WITH NO DATA;


ALTER MATERIALIZED VIEW public.team_cumulative_stats OWNER TO postgres;

