-- TOC entry 337 (class 1255 OID 19469)
-- Name: check_event_type_is_match(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.check_event_type_is_match() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
BEGIN
    IF (SELECT event_type FROM event WHERE event_id = NEW.event_id) != 'Match' THEN
        RAISE EXCEPTION 'event_id % is not a Match-type event', NEW.event_id;
    END IF;
    RETURN NEW;
END;
$$;


ALTER FUNCTION public.check_event_type_is_match() OWNER TO postgres;

--
-- TOC entry 298 (class 1255 OID 19471)
-- Name: check_match_result_vs_scores(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.check_match_result_vs_scores() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
BEGIN
    -- Only validate when both scores AND result are present
    IF NEW.result IS NOT NULL THEN
        IF NEW.result = 'Win'  AND NEW.team_score <= NEW.opponent_score THEN
            RAISE EXCEPTION
                'result is Win but team_score (%) <= opponent_score (%)',
                NEW.team_score, NEW.opponent_score;
        END IF;
        IF NEW.result = 'Loss' AND NEW.team_score >= NEW.opponent_score THEN
            RAISE EXCEPTION
                'result is Loss but team_score (%) >= opponent_score (%)',
                NEW.team_score, NEW.opponent_score;
        END IF;
        IF NEW.result = 'Draw' AND NEW.team_score != NEW.opponent_score THEN
            RAISE EXCEPTION
                'result is Draw but team_score (%) != opponent_score (%)',
                NEW.team_score, NEW.opponent_score;
        END IF;
    END IF;
    RETURN NEW;
END;
$$;


ALTER FUNCTION public.check_match_result_vs_scores() OWNER TO postgres;

--
-- TOC entry 260 (class 1255 OID 19257)
-- Name: check_player_has_role(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.check_player_has_role() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
BEGIN
    IF NOT EXISTS (
        SELECT 1 FROM user_role ur
        JOIN role r ON r.role_id = ur.role_id
        WHERE ur.user_id  = NEW.user_id
          AND r.role_name = 'Player'
          AND ur.status   = 'Approved'
    ) THEN
        RAISE EXCEPTION 'User % needs an approved Player role before a player_profile can be created',
            NEW.user_id;
    END IF;
    RETURN NEW;
END;
$$;


ALTER FUNCTION public.check_player_has_role() OWNER TO postgres;

--
-- TOC entry 321 (class 1255 OID 19236)
-- Name: check_staff_has_role(); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.check_staff_has_role() RETURNS trigger
    LANGUAGE plpgsql
    AS $$
DECLARE
    required_role role_name_type;
BEGIN
    required_role := CASE NEW.staff_role
        WHEN 'Head Coach' THEN 'Coach'
        WHEN 'Assistant'  THEN 'Coach'
        WHEN 'Medic'      THEN 'Medic'
        WHEN 'Analyst'    THEN 'Analyst'
    END;
    IF NOT EXISTS (
        SELECT 1 FROM user_role ur
        JOIN role r ON r.role_id = ur.role_id
        WHERE ur.user_id  = NEW.user_id
          AND ur.team_id  = NEW.team_id
          AND r.role_name = required_role
          AND ur.status   = 'Approved'
    ) THEN
        RAISE EXCEPTION 'User % needs an approved % role on team % before becoming team_staff',
            NEW.user_id, required_role, NEW.team_id;
    END IF;
    RETURN NEW;
END;
$$;


ALTER FUNCTION public.check_staff_has_role() OWNER TO postgres;

--
-- TOC entry 295 (class 1255 OID 19942)
-- Name: cleanup_expired_tokens(integer); Type: FUNCTION; Schema: public; Owner: postgres
--

CREATE FUNCTION public.cleanup_expired_tokens(p_retain_days integer DEFAULT 30) RETURNS integer
    LANGUAGE plpgsql
    AS $$
DECLARE
    rows_deleted INT;
BEGIN
    DELETE FROM refresh_token
    WHERE expires_at < NOW() - (p_retain_days || ' days')::INTERVAL
       OR (revoked_at IS NOT NULL
           AND revoked_at < NOW() - (p_retain_days || ' days')::INTERVAL);

    GET DIAGNOSTICS rows_deleted = ROW_COUNT;
    RETURN rows_deleted;
END;
$$;


ALTER FUNCTION public.cleanup_expired_tokens(p_retain_days integer) OWNER TO postgres;

--
