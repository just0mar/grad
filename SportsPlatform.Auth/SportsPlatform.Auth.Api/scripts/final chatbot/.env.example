GROQ_API_KEY=put_your_groq_api_key_here
GROQ_MODEL=put_your_groq_model_here
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_TIMEOUT=60
FAST_ANALYTICS_BYPASS=0
ENABLE_ANALYTICS_LLM_FORMATTING=0
APP_ENV=production

# --- Hybrid live-DB integration (Phase 9) ---
# Base URL of the .NET app the chatbot calls back into for live, non-PDF team data
# (roster, injuries, availability, schedule, attendance, fitness, plans).
# Leave BLANK to keep the hybrid OFF: AppDataClient no-ops and answers fall back to
# the prediction CSV / PDF RAG only. Set it to turn the live-DB lanes on.
APP_API_BASE_URL=
# Seconds before a live-DB read is abandoned (failures degrade gracefully, never raise).
APP_API_TIMEOUT=8
# Shared service token for BOTH directions of service-to-service calls. Must match the
# .NET app's Microservice:ServiceToken in appsettings.json. The chatbot sends this as
# "Authorization: Bearer <token>" when calling the app's /internal/teams/... endpoints,
# and validates the same value on its own webhook endpoint.
MICROSERVICE_SERVICE_TOKEN=put_the_same_token_as_dotnet_Microservice_ServiceToken_here

# Require the backend's bearer token on every chatbot endpoint except health probes.
REQUIRE_SERVICE_TOKEN=0

# Separate prediction machine. Leave blank to use the legacy local model fallback.
PREDICTION_SERVICE_BASE_URL=
PREDICTION_SERVICE_TOKEN=put_the_prediction_service_token_here
PREDICTION_SERVICE_TIMEOUT=900
