    LANGUAGE plpgsql
    AS $$
DECLARE
    rows_affected INT;
BEGIN
    UPDATE refresh_token
    SET    revoked_at     = NOW(),
           revoked_reason = p_reason
    WHERE  user_id   = p_user_id
