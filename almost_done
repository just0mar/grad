-- Name: team_cumulative_stats; Type: MATERIALIZED VIEW; Schema: public; Owner: postgres
--

CREATE MATERIALIZED VIEW public.team_cumulative_stats AS
 SELECT m.season_id,
    s.label AS season_label,
    e.team_id,
    count(*) AS matches_played,
    sum(
        CASE
            WHEN (m.result = 'Win'::public.match_result) THEN 1
            ELSE 0
        END) AS wins,
    sum(
        CASE
            WHEN (m.result = 'Loss'::public.match_result) THEN 1
            ELSE 0
        END) AS losses,
    sum(
        CASE
            WHEN (m.result = 'Draw'::public.match_result) THEN 1
            ELSE 0
        END) AS draws,
    sum(tgs.points_scored) AS total_points_scored,
    sum(tgs.points_conceded) AS total_points_conceded,
    sum(tgs.total_rebounds) AS total_rebounds,
    sum(tgs.total_assists) AS total_assists,
    sum(tgs.total_steals) AS total_steals,
    sum(tgs.total_blocks) AS total_blocks,
    sum(tgs.total_turnovers) AS total_turnovers,
    sum(tgs.total_fouls) AS total_fouls,
    sum(tgs.total_fg_made) AS total_fg_made,
    sum(tgs.total_fg_attempted) AS total_fg_attempted,
    sum(tgs.total_three_made) AS total_three_made,
    sum(tgs.total_ft_made) AS total_ft_made,
    round(avg(tgs.team_efficiency), 2) AS avg_efficiency
   FROM (((public.match m
     JOIN public.event e USING (event_id))
     JOIN public.season s ON ((s.season_id = m.season_id)))
     JOIN public.team_game_stats tgs ON ((tgs.match_id = m.match_id)))
  GROUP BY m.season_id, s.label, e.team_id
  WITH NO DATA;


